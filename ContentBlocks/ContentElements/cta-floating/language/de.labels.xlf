<?xml version="1.0" encoding="utf-8"?>
<xliff version="2.0" xmlns="urn:oasis:names:tc:xliff:document:2.0" srcLang="en" trgLang="de">
  <file id="cta-floating">
    <unit id="title">
      <segment state="final">
        <source>Floating Call to Action</source>
        <target>Floating Call to Action</target>
      </segment>
    </unit>
    <unit id="description">
      <segment state="final">
        <source>Dock a persistent action bar to the top or bottom edge of the viewport so the offer stays in view as visitors scroll.</source>
        <target>Dock eine dauerhafte Aktionsleiste am oberen oder unteren Rand des Viewports an, damit das Angebot beim Scrollen sichtbar bleibt.</target>
      </segment>
    </unit>
    <unit id="region.label">
      <segment state="final">
        <source>Call to action</source>
        <target>Handlungsaufforderung</target>
      </segment>
    </unit>
    <unit id="link.newTab">
      <segment state="final">
        <source>(opens in a new tab)</source>
        <target>(wird in einem neuen Tab geöffnet)</target>
      </segment>
    </unit>
  </file>
</xliff>
