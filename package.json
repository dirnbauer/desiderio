{
  "name": "desiderio",
  "private": true,
  "version": "0.0.0",
  "description": "Tailwind v4 and shadcn/ui theme build for the Desiderio TYPO3 extension.",
  "scripts": {
    "build:css": "tailwindcss -i Resources/Private/Tailwind/desiderio.css -o Resources/Public/Css/desiderio-tailwind.css --minify",
    "watch:css": "tailwindcss -i Resources/Private/Tailwind/desiderio.css -o Resources/Public/Css/desiderio-tailwind.css --watch"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/cli": "^4.2.4",
    "alpinejs": "^3.15.11",
    "shadcn": "^4.4.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  }
}
