  <file id="mega-menu">
    <unit id="title">
      <segment>
        <source>Mega Menu Panel</source>
      </segment>
    </unit>
    <unit id="description">
      <segment>
        <source>Renders a mega-menu panel in full-width or two-column layout: a brand header with tagline, eyebrow badge, and CTA button, an optional rich-text intro column, and multiple titled menu groups each holding up to five labeled links plus a short description. Use it for: sitemap-style navigation overviews, category or product hubs, service directories with grouped links. Prefer 'Dropdown Navigation Bar' for a header with dropdowns, 'Sitemap Grid' for a footer sitemap.</source>
      </segment>
    </unit>
