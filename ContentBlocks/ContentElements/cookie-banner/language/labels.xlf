<?xml version="1.0" encoding="utf-8"?>
<xliff version="2.0" xmlns="urn:oasis:names:tc:xliff:document:2.0" srcLang="en">
  <file id="cookie-banner">
    <unit id="title">
      <segment>
        <source>Cookie Consent Banner</source>
      </segment>
    </unit>
    <unit id="description">
      <segment>
        <source>A dismissible consent region docked to the top or bottom of the viewport, showing a heading with shield icon, a rich-text consent message, accept and decline buttons with editable labels, and an optional manage-preferences link. Use it for: cookie and tracking consent notices, 'we use cookies' texts, privacy opt-in prompts shown on arrival. Prefer 'GDPR Consent Banner' when visitors must opt in per cookie category; this element offers a simple accept-or-decline choice.</source>
      </segment>
    </unit>
    <unit id="field.content">
      <segment>
        <source>Cookie message</source>
      </segment>
    </unit>
    <unit id="field.content.description">
      <segment>
        <source>Explain what cookies you set and why. Keep it short and link to the full policy.</source>
      </segment>
    </unit>
    <unit id="field.accept_text">
      <segment>
        <source>Accept button label</source>
      </segment>
    </unit>
    <unit id="field.decline_text">
      <segment>
        <source>Decline button label</source>
      </segment>
    </unit>
    <unit id="field.settings_text">
      <segment>
        <source>Settings link label</source>
      </segment>
    </unit>
    <unit id="field.settings_link">
      <segment>
        <source>Settings page link</source>
      </segment>
    </unit>
    <unit id="field.settings_link.description">
      <segment>
        <source>Where the settings label points, e.g. a dedicated cookie preferences page.</source>
      </segment>
    </unit>
    <unit id="item.position.bottom">
      <segment>
        <source>Bottom of the viewport</source>
      </segment>
    </unit>
    <unit id="item.position.top">
      <segment>
        <source>Top of the viewport</source>
      </segment>
    </unit>
    <unit id="aria.region">
      <segment>
        <source>{0}</source>
      </segment>
    </unit>
    <unit id="aria.region.fallback">
      <segment>
        <source>Cookie consent</source>
      </segment>
    </unit>
  </file>
</xliff>
