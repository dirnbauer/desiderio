{
  "name": "desiderio",
  "private": true,
  "version": "0.0.0",
  "description": "Tailwind v4 and shadcn/ui theme build for the Desiderio TYPO3 extension.",
  "scripts": {
    "build:css": "tailwindcss -i Resources/Private/Tailwind/desiderio.css -o Resources/Public/Css/desiderio-tailwind.css --minify",
    "build:desiderio-css": "node Build/Scripts/build-desiderio-css.mjs",
    "build:prism": "node Build/Scripts/build-prism-lite.mjs",
    "build:hljs": "node Build/Scripts/build-hljs-lite.mjs",
    "build:iconfonts": "node Build/Scripts/sync-icon-fonts.mjs",
    "build:hugeicons-font": "node Build/Scripts/build-hugeicons-font.mjs",
    "watch:css": "tailwindcss -i Resources/Private/Tailwind/desiderio.css -o Resources/Public/Css/desiderio-tailwind.css --watch",
    "shadcn:info": "shadcn info --json",
    "shadcn:sync-fluid": "php Build/Scripts/sync-shadcn-fluid-primitives.php",
    "registry:build": "shadcn build --output Resources/Public/ShadcnRegistry"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@phosphor-icons/web": "^2.1.2",
    "@tabler/icons-webfont": "^3.44.0",
    "@tailwindcss/cli": "^4.2.4",
    "lucide-static": "^1.17.0",
    "prismjs": "^1.30.0",
    "remixicon": "^4.9.1",
    "shadcn": "^4.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "@hugeicons/core-free-icons": "^4.2.0",
    "esbuild": "^0.28.1",
    "fantasticon": "^4.1.0"
  }
}
