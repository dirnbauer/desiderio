# EXT:solr's page indexer refuses to index a rendered page unless
# config.index_enable is set; without it queue items stay pending forever
# (the sub-request answers HTTP 200 with success=false, so no error is logged).
config.index_enable = 1

plugin.tx_solr.index.queue.pages {
  allowedPageTypes = 1,7,137,138
  additionalWhereClause = (doktype IN(1,137,138) OR (doktype=7 AND mount_pid_ol=0)) AND no_search = 0
}

tx_solr_suggest = PAGE
tx_solr_suggest {
  typeNum = 7384
  config {
    disableAllHeaderCode = 1
    xhtml_cleaning = 0
    admPanel = 0
    additionalHeaders.10.header = Content-type: application/json
    no_cache = 0
    debug = 0
  }

  10 = USER
  10 {
    userFunc = TYPO3\CMS\Extbase\Core\Bootstrap->run
    extensionName = Solr
    pluginName = pi_suggest
    vendorName = ApacheSolrForTypo3
    controller = Suggest
    action = suggest
  }
}

plugin.tx_solr {
  view {
    templateRootPaths.100 = EXT:desiderio/Resources/Private/Solr/Templates/
    partialRootPaths.100 = EXT:desiderio/Resources/Private/Solr/Partials/
    layoutRootPaths.100 = EXT:desiderio/Resources/Private/Solr/Layouts/
  }

  suggest = 1
  suggest {
    numberOfSuggestions = 10
    suggestField = spell
    showTopResults = 1
    numberOfTopResults = 5
  }
}

page {
  includeJSFooterlibs {
    solr-jquery >
    solr-autocomplete >
    solr-suggest >
  }

  includeCSS {
    solr-suggest >
    solrSuggest >
  }
}
