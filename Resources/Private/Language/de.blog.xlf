<?xml version="1.0" encoding="utf-8"?>
<xliff version="2.0" xmlns="urn:oasis:names:tc:xliff:document:2.0" srcLang="en" trgLang="de">
  <file id="desiderio-blog">

    <!-- Article (single post) -->
    <unit id="post.breadcrumb.label">
      <segment state="final"><source>Breadcrumb</source><target>Brotkrumennavigation</target></segment>
    </unit>
    <unit id="post.breadcrumb.home">
      <segment state="final"><source>Blog</source><target>Blog</target></segment>
    </unit>
    <unit id="post.kicker.default">
      <segment state="final"><source>Article</source><target>Artikel</target></segment>
    </unit>
    <unit id="post.byline.prefix">
      <segment state="final"><source>By</source><target>Von</target></segment>
    </unit>
    <unit id="post.meta.label">
      <segment state="final"><source>Article details</source><target>Artikeldetails</target></segment>
    </unit>
    <unit id="post.published.label">
      <segment state="final"><source>Published</source><target>Veroeffentlicht</target></segment>
    </unit>
    <unit id="post.updated.label">
      <segment state="final"><source>Updated</source><target>Aktualisiert</target></segment>
    </unit>
    <unit id="post.readingTime">
      <segment state="final"><source>{minutes, plural, one {# min read} other {# min read}}</source><target>{minutes, plural, one {# Min. Lesezeit} other {# Min. Lesezeit}}</target></segment>
    </unit>
    <unit id="post.readingTime.aria">
      <segment state="final"><source>Estimated reading time: {minutes, plural, one {one minute} other {# minutes}}</source><target>Geschaetzte Lesezeit: {minutes, plural, one {eine Minute} other {# Minuten}}</target></segment>
    </unit>
    <unit id="post.readingTime.template">
      <segment state="final"><source>{n} min read</source><target>{n} Min. Lesezeit</target></segment>
    </unit>
    <unit id="post.readingTime.template.aria">
      <segment state="final"><source>Estimated reading time: {n} min</source><target>Geschaetzte Lesezeit: {n} Min.</target></segment>
    </unit>
    <unit id="post.progress.label">
      <segment state="final"><source>Reading progress</source><target>Lesefortschritt</target></segment>
    </unit>
    <unit id="post.body.label">
      <segment state="final"><source>Article body</source><target>Artikelinhalt</target></segment>
    </unit>

    <!-- Counts (ICU plural) -->
    <unit id="post.comments.count">
      <segment state="final"><source>{count, plural, =0 {No comments yet} one {# comment} other {# comments}}</source><target>{count, plural, =0 {Noch keine Kommentare} one {# Kommentar} other {# Kommentare}}</target></segment>
    </unit>
    <unit id="post.tags.label">
      <segment state="final"><source>{count, plural, one {Tag} other {Tags}}</source><target>{count, plural, one {Schlagwort} other {Schlagwoerter}}</target></segment>
    </unit>
    <unit id="post.categories.label">
      <segment state="final"><source>{count, plural, one {Category} other {Categories}}</source><target>{count, plural, one {Kategorie} other {Kategorien}}</target></segment>
    </unit>

    <!-- List view -->
    <unit id="list.heading">
      <segment state="final"><source>From the blog</source><target>Aus dem Blog</target></segment>
    </unit>
    <unit id="list.intro">
      <segment state="final"><source>Notes on what we are building, what we are learning, and where the craft is heading.</source><target>Notizen darueber, was wir bauen, was wir lernen und wohin sich das Handwerk entwickelt.</target></segment>
    </unit>
    <unit id="list.count">
      <segment state="final"><source>{count, plural, =0 {No articles yet} one {# article} other {# articles}}</source><target>{count, plural, =0 {Noch keine Artikel} one {# Artikel} other {# Artikel}}</target></segment>
    </unit>
    <unit id="list.featured.label">
      <segment state="final"><source>Featured</source><target>Empfohlen</target></segment>
    </unit>
    <unit id="list.empty.title">
      <segment state="final"><source>Nothing published here yet</source><target>Hier wurde noch nichts veroeffentlicht</target></segment>
    </unit>
    <unit id="list.empty.description">
      <segment state="final"><source>New articles will appear here as soon as they go live. Check back soon.</source><target>Neue Artikel erscheinen hier, sobald sie online sind. Schauen Sie bald wieder vorbei.</target></segment>
    </unit>
    <unit id="list.region.label">
      <segment state="final"><source>Article list</source><target>Artikelliste</target></segment>
    </unit>

    <!-- Card / teaser -->
    <unit id="card.readMore">
      <segment state="final"><source>Read article</source><target>Artikel lesen</target></segment>
    </unit>
    <unit id="card.readMore.aria">
      <segment state="final"><source>Read the article: {title}</source><target>Artikel lesen: {title}</target></segment>
    </unit>

    <!-- Related & sidebar -->
    <unit id="related.heading">
      <segment state="final"><source>Keep reading</source><target>Weiterlesen</target></segment>
    </unit>
    <unit id="related.intro">
      <segment state="final"><source>More articles picked to pair with this one.</source><target>Weitere Artikel, die zu diesem passen.</target></segment>
    </unit>
    <unit id="sidebar.label">
      <segment state="final"><source>Article tools and related reading</source><target>Artikelwerkzeuge und verwandte Beitraege</target></segment>
    </unit>

    <!-- Author -->
    <unit id="author.about">
      <segment state="final"><source>About the author</source><target>Ueber die Autorin / den Autor</target></segment>
    </unit>
    <unit id="author.morePosts">
      <segment state="final"><source>More articles by this author</source><target>Weitere Artikel dieser Autorin / dieses Autors</target></segment>
    </unit>
    <unit id="author.posts.count">
      <segment state="final"><source>{count, plural, one {# article} other {# articles}}</source><target>{count, plural, one {# Artikel} other {# Artikel}}</target></segment>
    </unit>

    <!-- Comments -->
    <unit id="comments.heading">
      <segment state="final"><source>{count, plural, =0 {Join the conversation} one {# comment} other {# comments}}</source><target>{count, plural, =0 {Diskutieren Sie mit} one {# Kommentar} other {# Kommentare}}</target></segment>
    </unit>
    <unit id="comments.form.heading">
      <segment state="final"><source>Leave a comment</source><target>Kommentar schreiben</target></segment>
    </unit>
    <unit id="comments.form.intro">
      <segment state="final"><source>Your email address will not be published.</source><target>Ihre E-Mail-Adresse wird nicht veroeffentlicht.</target></segment>
    </unit>
    <unit id="comments.closed">
      <segment state="final"><source>Comments are closed for this article.</source><target>Kommentare sind fuer diesen Artikel geschlossen.</target></segment>
    </unit>

    <!-- Pagination -->
    <unit id="pagination.label">
      <segment state="final"><source>Pagination, {totalPages, plural, one {one page} other {# pages}}</source><target>Seitennavigation, {totalPages, plural, one {eine Seite} other {# Seiten}}</target></segment>
    </unit>
    <unit id="pagination.previous">
      <segment state="final"><source>Previous</source><target>Zurueck</target></segment>
    </unit>
    <unit id="pagination.next">
      <segment state="final"><source>Next</source><target>Weiter</target></segment>
    </unit>
    <unit id="pagination.aria.previous">
      <segment state="final"><source>Go to previous page</source><target>Zur vorherigen Seite</target></segment>
    </unit>
    <unit id="pagination.aria.next">
      <segment state="final"><source>Go to next page</source><target>Zur naechsten Seite</target></segment>
    </unit>
    <unit id="pagination.aria.goToPage">
      <segment state="final"><source>Go to page {page} of {totalPages, plural, one {one page} other {# pages}}</source><target>Zu Seite {page} von {totalPages, plural, one {einer Seite} other {# Seiten}}</target></segment>
    </unit>
    <unit id="pagination.aria.currentPage">
      <segment state="final"><source>Page {page} of {totalPages, plural, one {one page} other {# pages}}</source><target>Seite {page} von {totalPages, plural, one {einer Seite} other {# Seiten}}</target></segment>
    </unit>

  </file>
</xliff>
