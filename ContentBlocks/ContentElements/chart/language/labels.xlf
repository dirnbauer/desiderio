<?xml version="1.0" encoding="utf-8"?>
<xliff version="2.0" xmlns="urn:oasis:names:tc:xliff:document:2.0" srcLang="en">
  <file id="chart">
    <unit id="title">
      <segment>
        <source>Chart</source>
      </segment>
    </unit>
    <unit id="description">
      <segment>
        <source>Pick area, line, or bar from one configurable element for a quick everyday chart without choosing a dedicated type.</source>
      </segment>
    </unit>
    <unit id="chart.aria_fallback">
      <segment>
        <source>Data chart</source>
      </segment>
    </unit>
    <unit id="chart.series_name.label">
      <segment>
        <source>Series name</source>
      </segment>
    </unit>
    <unit id="chart.series_name.description">
      <segment>
        <source>Name of the measured series, e.g. "Active users". Used as the value column heading in the screen-reader data table.</source>
      </segment>
    </unit>
    <unit id="chart.value_unit.label">
      <segment>
        <source>Value unit</source>
      </segment>
    </unit>
    <unit id="chart.value_unit.description">
      <segment>
        <source>Unit of the values, e.g. "users", "%", or "EUR". Announced to screen readers alongside the numbers.</source>
      </segment>
    </unit>
    <unit id="chart.data_summary.label">
      <segment>
        <source>Accessible summary</source>
      </segment>
    </unit>
    <unit id="chart.data_summary.description">
      <segment>
        <source>One or two sentences describing the key takeaway of the chart. Read out to screen-reader users as the description of the graphic.</source>
      </segment>
    </unit>
    <unit id="chart.data_points.label">
      <segment>
        <source>Data points (accessible table)</source>
      </segment>
    </unit>
    <unit id="chart.data_points.description">
      <segment>
        <source>Each data point renders as a row in a visually hidden table so the numbers stay available without the chart graphic. Mirror the values from the chart data above.</source>
      </segment>
    </unit>
    <unit id="chart.data_points.point_label">
      <segment>
        <source>Category label</source>
      </segment>
    </unit>
    <unit id="chart.data_points.point_value">
      <segment>
        <source>Value</source>
      </segment>
    </unit>
    <unit id="chart.table.category">
      <segment>
        <source>Category</source>
      </segment>
    </unit>
    <unit id="chart.table.value_default">
      <segment>
        <source>Value</source>
      </segment>
    </unit>
    <unit id="chart.table.unit_caption">
      <segment>
        <source>values in {0}</source>
      </segment>
    </unit>
    <unit id="chart.stat.peak">
      <segment>
        <source>Peak</source>
      </segment>
    </unit>
    <unit id="chart.stat.net_change">
      <segment>
        <source>Net change</source>
      </segment>
    </unit>
    <unit id="chart.trend.up">
      <segment>
        <source>Trending up:</source>
      </segment>
    </unit>
    <unit id="chart.trend.down">
      <segment>
        <source>Trending down:</source>
      </segment>
    </unit>
    <unit id="chart.trend.flat">
      <segment>
        <source>No net change:</source>
      </segment>
    </unit>
  </file>
</xliff>
